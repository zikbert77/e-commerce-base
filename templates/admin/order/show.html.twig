{% extends 'admin/base.html.twig' %}

{% block title %}Order {{ order.uid }}{% endblock %}
{% block page_title %}Orders / {{ order.uid }}{% endblock %}

{% block body %}
<div class="d-flex align-items-center justify-content-between mb-4">
    <h5 class="mb-0 fw-bold">Order #{{ order.uid }}</h5>
    <a href="{{ path('admin_order_index') }}" class="btn btn-sm btn-outline-secondary">
        <i class="bi bi-arrow-left me-1"></i> Back to orders
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        {# Order Items #}
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Order Items</h6>
            </div>
            <div class="card-body p-0">
                {% if order.orderItems is empty %}
                    <p class="text-muted text-center py-4 mb-0">No items.</p>
                {% else %}
                    <table class="table align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="ps-4">Product</th>
                                <th class="text-center">Qty</th>
                                <th class="text-end">Price</th>
                                <th class="text-end pe-4">Total</th>
                            </tr>
                        </thead>
                        <tbody>
                            {% for item in order.orderItems %}
                            <tr>
                                <td class="ps-4 fw-semibold">{{ item.productTitle }}</td>
                                <td class="text-center">{{ item.qty }}</td>
                                <td class="text-end">${{ (item.price / 100)|number_format(2) }}</td>
                                <td class="text-end pe-4">${{ (item.totalAmount / 100)|number_format(2) }}</td>
                            </tr>
                            {% endfor %}
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="3" class="text-end fw-semibold ps-4">Subtotal</td>
                                <td class="text-end pe-4">${{ (order.subtotalAmount / 100)|number_format(2) }}</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end fw-semibold ps-4">Discount</td>
                                <td class="text-end pe-4">-${{ (order.discountAmount / 100)|number_format(2) }}</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end fw-semibold ps-4">Shipping</td>
                                <td class="text-end pe-4">${{ (order.shippingCostAmount / 100)|number_format(2) }}</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end fw-semibold ps-4">Tax</td>
                                <td class="text-end pe-4">${{ (order.taxAmount / 100)|number_format(2) }}</td>
                            </tr>
                            <tr>
                                <td colspan="3" class="text-end fw-bold ps-4">Total</td>
                                <td class="text-end pe-4 fw-bold">${{ (order.totalAmount / 100)|number_format(2) }}</td>
                            </tr>
                        </tfoot>
                    </table>
                {% endif %}
            </div>
        </div>

        {# Customer Info #}
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Customer Information</h6>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">Name</div>
                        <div>{{ order.customerFirstName }} {{ order.customerLastName }}</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">Email</div>
                        <div>{{ order.customerEmail }}</div>
                    </div>
                    <div class="col-md-6">
                        <div class="text-muted small mb-1">Phone</div>
                        <div>{{ order.customerPhone ?? '—' }}</div>
                    </div>
                    <div class="col-12">
                        <div class="text-muted small mb-1">Shipping Address</div>
                        <div>{{ order.shippingAddress }}</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        {# Status Update #}
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Update Status</h6>
            </div>
            <div class="card-body">
                {{ form_start(statusForm) }}
                {{ form_row(statusForm.status) }}
                <button type="submit" class="btn btn-primary w-100 mt-2">
                    <i class="bi bi-check-lg me-1"></i> Update Status
                </button>
                {{ form_end(statusForm) }}
            </div>
        </div>

        {# Order Meta #}
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white py-3">
                <h6 class="mb-0 fw-semibold">Order Details</h6>
            </div>
            <div class="card-body">
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Order ID</span>
                    <span class="fw-semibold small">{{ order.uid }}</span>
                </div>
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Created</span>
                    <span class="small">{{ order.createdAt|date('Y-m-d H:i') }}</span>
                </div>
                {% if order.paidAt %}
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Paid at</span>
                    <span class="small">{{ order.paidAt|date('Y-m-d H:i') }}</span>
                </div>
                {% endif %}
                {% if order.shippedAt %}
                <div class="d-flex justify-content-between mb-2">
                    <span class="text-muted small">Shipped at</span>
                    <span class="small">{{ order.shippedAt|date('Y-m-d H:i') }}</span>
                </div>
                {% endif %}
                {% if order.completedAt %}
                <div class="d-flex justify-content-between">
                    <span class="text-muted small">Completed at</span>
                    <span class="small">{{ order.completedAt|date('Y-m-d H:i') }}</span>
                </div>
                {% endif %}
                {% if order.relatedUser %}
                <hr>
                <div class="text-muted small">Linked account: {{ order.relatedUser.email }}</div>
                {% endif %}
            </div>
        </div>
    </div>
</div>
{% endblock %}
