{% extends 'admin/base.html.twig' %}

{% block title %}Orders{% endblock %}
{% block page_title %}Orders{% endblock %}

{% block body %}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white py-3">
        <h6 class="mb-0 fw-semibold">All Orders</h6>
    </div>
    <div class="card-body p-0">
        {% if orders is empty %}
            <p class="text-muted text-center py-4 mb-0">No orders yet.</p>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Order #</th>
                            <th>Customer</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th>Paid</th>
                            <th>Date</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in orders %}
                        <tr>
                            <td class="ps-4 fw-semibold">{{ order.uid }}</td>
                            <td>
                                <div>{{ order.customerFirstName }} {{ order.customerLastName }}</div>
                                <div class="text-muted small">{{ order.customerEmail }}</div>
                            </td>
                            <td>
                                {% set statusVal = order.status.value %}
                                {% if statusVal == 4 %}
                                    <span class="badge rounded-pill text-bg-success">{{ order.status.name }}</span>
                                {% elseif statusVal == 5 %}
                                    <span class="badge rounded-pill text-bg-danger">{{ order.status.name }}</span>
                                {% elseif statusVal == 2 %}
                                    <span class="badge rounded-pill text-bg-primary">{{ order.status.name }}</span>
                                {% else %}
                                    <span class="badge rounded-pill text-bg-warning text-dark">{{ order.status.name }}</span>
                                {% endif %}
                            </td>
                            <td>${{ (order.totalAmount / 100)|number_format(2) }}</td>
                            <td>${{ (order.paidAmount / 100)|number_format(2) }}</td>
                            <td class="text-muted small">{{ order.createdAt|date('Y-m-d') }}</td>
                            <td class="text-end pe-4">
                                <a href="{{ path('admin_order_show', {id: order.id}) }}" class="btn btn-sm btn-outline-primary">
                                    <i class="bi bi-eye"></i> View
                                </a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
