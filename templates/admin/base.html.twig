<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{% block title %}Admin{% endblock %} — Admin Panel</title>
    {% block javascripts %}
        {{ importmap('admin') }}
    {% endblock %}
</head>
<body class="bg-light">

{# ===== SIDEBAR ===== #}
<nav class="admin-sidebar" id="adminSidebar">
    <div class="sidebar-brand">
        <div class="brand-icon">EC</div>
        <a href="{{ path('admin_dashboard') }}" class="text-decoration-none fw-bold fs-6 text-dark">E-Commerce</a>
    </div>

    <div class="sidebar-nav">
        <div class="nav-label">Main</div>
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link {{ app.request.pathinfo == '/admin' or app.request.pathinfo == '/admin/' ? 'active' : '' }}"
                   href="{{ path('admin_dashboard') }}">
                    <i class="bi bi-speedometer2"></i> Dashboard
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {{ app.request.pathinfo starts with '/admin/products' ? 'active' : '' }}"
                   href="{{ path('admin_product_index') }}">
                    <i class="bi bi-box-seam"></i> Products
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {{ app.request.pathinfo starts with '/admin/categories' ? 'active' : '' }}"
                   href="{{ path('admin_category_index') }}">
                    <i class="bi bi-diagram-3"></i> Categories
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {{ app.request.pathinfo starts with '/admin/users' ? 'active' : '' }}"
                   href="{{ path('admin_user_index') }}">
                    <i class="bi bi-people"></i> Users
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link {{ app.request.pathinfo starts with '/admin/orders' ? 'active' : '' }}"
                   href="{{ path('admin_order_index') }}">
                    <i class="bi bi-bag-check"></i> Orders
                </a>
            </li>
        </ul>
    </div>

    <div class="sidebar-footer">
        <ul class="nav flex-column">
            <li class="nav-item">
                <a class="nav-link text-muted" href="#">
                    <i class="bi bi-gear"></i> Settings
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link text-danger" href="{{ path('app_logout') }}">
                    <i class="bi bi-box-arrow-left"></i> Logout
                </a>
            </li>
        </ul>
    </div>
</nav>

{# ===== TOPBAR ===== #}
<header class="admin-topbar">
    <div class="fw-semibold text-secondary small">{% block page_title %}Dashboard{% endblock %}</div>
    <div class="flex-grow-1"></div>

    <div class="d-none d-md-block">
        <input type="search" class="form-control form-control-sm" placeholder="Search..." style="width:200px">
    </div>

    {# Notification bell #}
    <div class="dropdown">
        <a href="#" class="topbar-action" data-bs-toggle="dropdown" aria-expanded="false">
            <i class="bi bi-bell"></i>
        </a>
        <div class="dropdown-menu dropdown-menu-end p-3" style="min-width:280px">
            <p class="text-muted small mb-0">No new notifications</p>
        </div>
    </div>

    {# User dropdown #}
    <div class="dropdown">
        <a class="d-flex align-items-center gap-2 text-decoration-none text-dark dropdown-toggle"
           href="#" data-bs-toggle="dropdown" aria-expanded="false">
            <div class="rounded-circle text-white d-flex align-items-center justify-content-center fw-bold"
                 style="width:32px;height:32px;background:var(--admin-accent);font-size:13px;flex-shrink:0">
                {{ app.user ? app.user.firstName|first|upper : 'A' }}
            </div>
            <span class="d-none d-md-inline small fw-semibold">
                {{ app.user ? (app.user.firstName ~ ' ' ~ app.user.lastName) : 'Admin' }}
            </span>
        </a>
        <ul class="dropdown-menu dropdown-menu-end">
            <li>
                <div class="dropdown-item-text small text-muted">
                    {{ app.user ? app.user.email : '' }}
                </div>
            </li>
            <li><hr class="dropdown-divider"></li>
            <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Profile</a></li>
            <li><hr class="dropdown-divider"></li>
            <li>
                <a class="dropdown-item text-danger" href="{{ path('app_logout') }}">
                    <i class="bi bi-box-arrow-left me-2"></i>Logout
                </a>
            </li>
        </ul>
    </div>

    {# Mobile sidebar toggle #}
    <button class="btn btn-sm btn-outline-secondary d-md-none ms-1"
            onclick="document.getElementById('adminSidebar').classList.toggle('is-open')">
        <i class="bi bi-list"></i>
    </button>
</header>

{# ===== MAIN CONTENT ===== #}
<main class="admin-content">
    {% for type, messages in app.flashes %}
        {% for message in messages %}
            <div class="alert alert-{{ type == 'error' ? 'danger' : type }} alert-dismissible fade show mb-4" role="alert">
                {{ message }}
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        {% endfor %}
    {% endfor %}

    {% block body %}{% endblock %}
</main>

</body>
</html>
