{% extends 'admin/base.html.twig' %}

{% block title %}Dashboard{% endblock %}
{% block page_title %}Dashboard{% endblock %}

{% block body %}
<div class="row g-4 mb-4">
    <div class="col-sm-6 col-xl-3">
        <div class="admin-stat-card">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="admin-stat-icon" style="background:#eef1ff">
                    <i class="bi bi-box-seam" style="color:var(--admin-accent)"></i>
                </div>
                <span class="text-muted small fw-medium">Products</span>
            </div>
            <div class="fs-2 fw-bold">{{ productCount }}</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="admin-stat-card">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="admin-stat-icon" style="background:#fef9c3">
                    <i class="bi bi-diagram-3" style="color:#854d0e"></i>
                </div>
                <span class="text-muted small fw-medium">Categories</span>
            </div>
            <div class="fs-2 fw-bold">{{ categoryCount }}</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="admin-stat-card">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="admin-stat-icon" style="background:#dcfce7">
                    <i class="bi bi-bag-check" style="color:#15803d"></i>
                </div>
                <span class="text-muted small fw-medium">Orders</span>
            </div>
            <div class="fs-2 fw-bold">{{ orderCount }}</div>
        </div>
    </div>
    <div class="col-sm-6 col-xl-3">
        <div class="admin-stat-card">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="admin-stat-icon" style="background:#fce7f3">
                    <i class="bi bi-people" style="color:#9d174d"></i>
                </div>
                <span class="text-muted small fw-medium">Users</span>
            </div>
            <div class="fs-2 fw-bold">{{ userCount }}</div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between py-3">
        <h6 class="mb-0 fw-semibold">Recent Orders</h6>
        <a href="{{ path('admin_order_index') }}" class="btn btn-sm btn-outline-secondary">View all</a>
    </div>
    <div class="card-body p-0">
        {% if recentOrders is empty %}
            <p class="text-muted text-center py-4 mb-0">No orders yet.</p>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">Order #</th>
                            <th>Customer</th>
                            <th>Status</th>
                            <th>Total</th>
                            <th>Date</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for order in recentOrders %}
                        <tr>
                            <td class="ps-4 fw-semibold text-muted">{{ order.uid }}</td>
                            <td>{{ order.customerFirstName }} {{ order.customerLastName }}</td>
                            <td>
                                {% set statusVal = order.status.value %}
                                {% if statusVal == 4 %}
                                    <span class="badge rounded-pill text-bg-success">{{ order.status.name }}</span>
                                {% elseif statusVal == 5 %}
                                    <span class="badge rounded-pill text-bg-danger">{{ order.status.name }}</span>
                                {% elseif statusVal == 2 %}
                                    <span class="badge rounded-pill text-bg-primary">{{ order.status.name }}</span>
                                {% else %}
                                    <span class="badge rounded-pill text-bg-warning text-dark">{{ order.status.name }}</span>
                                {% endif %}
                            </td>
                            <td>${{ (order.totalAmount / 100)|number_format(2) }}</td>
                            <td class="text-muted small">{{ order.createdAt|date('Y-m-d') }}</td>
                            <td>
                                <a href="{{ path('admin_order_show', {id: order.id}) }}" class="btn btn-sm btn-outline-primary">View</a>
                            </td>
                        </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
