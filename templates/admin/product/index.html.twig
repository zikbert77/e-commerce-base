{% extends 'admin/base.html.twig' %}

{% block title %}Products{% endblock %}
{% block page_title %}Products{% endblock %}

{% block body %}
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex align-items-center justify-content-between py-3">
        <h6 class="mb-0 fw-semibold">All Products</h6>
        <a href="{{ path('admin_product_create') }}" class="btn btn-sm btn-primary">
            <i class="bi bi-plus-lg me-1"></i> New Product
        </a>
    </div>
    <div class="card-body p-0">
        {% if products is empty %}
            <p class="text-muted text-center py-4 mb-0">No products yet.</p>
        {% else %}
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">#</th>
                            <th>Title</th>
                            <th>Category</th>
                            <th>Status</th>
                            <th>Created</th>
                            <th class="text-end pe-4">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for product in products %}
                            {% set info = product.getProductInfoByLocale('en') %}
                            <tr>
                                <td class="ps-4 text-muted">{{ product.id }}</td>
                                <td>
                                    <div class="fw-semibold">{{ info ? info.title : '(no title)' }}</div>
                                    {% if info %}<div class="text-muted small">{{ info.slug }}</div>{% endif %}
                                </td>
                                <td>
                                    {% if product.category %}
                                        {% set catInfo = product.category.categoryInfos.first() %}
                                        {{ catInfo ? catInfo.title : 'Category #' ~ product.category.id }}
                                    {% else %}
                                        <span class="text-muted">—</span>
                                    {% endif %}
                                </td>
                                <td>
                                    {% if product.status == 1 %}
                                        <span class="badge rounded-pill text-bg-success">Active</span>
                                    {% else %}
                                        <span class="badge rounded-pill text-bg-secondary">Inactive</span>
                                    {% endif %}
                                </td>
                                <td class="text-muted small">{{ product.createdAt|date('Y-m-d') }}</td>
                                <td class="text-end pe-4">
                                    <div class="d-flex gap-2 justify-content-end">
                                        <a href="{{ path('admin_product_edit', {id: product.id}) }}" class="btn btn-sm btn-outline-primary">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form method="post" action="{{ path('admin_product_delete', {id: product.id}) }}"
                                              onsubmit="return confirm('Delete this product?')">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete_product_' ~ product.id) }}">
                                            <button type="submit" class="btn btn-sm btn-outline-danger">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
            </div>
        {% endif %}
    </div>
</div>
{% endblock %}
